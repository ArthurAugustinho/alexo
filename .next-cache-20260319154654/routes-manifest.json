{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/produtos/[id]/variantes",
      "regex": "^/admin/produtos/([^/]+?)/variantes(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/produtos/(?<nxtPid>[^/]+?)/variantes(?:/)?$"
    },
    {
      "page": "/api/auth/[...all]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPall": "nxtPall"
      },
      "namedRegex": "^/api/auth/(?<nxtPall>.+?)(?:/)?$"
    },
    {
      "page": "/category/[slug]",
      "regex": "^/category/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/category/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/product/[slug]",
      "regex": "^/product/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/product/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/product-variant/[slug]",
      "regex": "^/product\\-variant/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/product\\-variant/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/vitrine",
      "regex": "^/admin/vitrine(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/vitrine(?:/)?$"
    },
    {
      "page": "/admin/vitrine/banners",
      "regex": "^/admin/vitrine/banners(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/vitrine/banners(?:/)?$"
    },
    {
      "page": "/admin/vitrine/mais-vendidos",
      "regex": "^/admin/vitrine/mais\\-vendidos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/vitrine/mais\\-vendidos(?:/)?$"
    },
    {
      "page": "/authentication",
      "regex": "^/authentication(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/authentication(?:/)?$"
    },
    {
      "page": "/cart/confirmation",
      "regex": "^/cart/confirmation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cart/confirmation(?:/)?$"
    },
    {
      "page": "/cart/identification",
      "regex": "^/cart/identification(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cart/identification(?:/)?$"
    },
    {
      "page": "/checkout/cancel",
      "regex": "^/checkout/cancel(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout/cancel(?:/)?$"
    },
    {
      "page": "/checkout/success",
      "regex": "^/checkout/success(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout/success(?:/)?$"
    },
    {
      "page": "/checkout/sucess",
      "regex": "^/checkout/sucess(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout/sucess(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/my-orders",
      "regex": "^/my\\-orders(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/my\\-orders(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}